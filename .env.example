# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=cisco_orders

# Random secret — use: openssl rand -base64 32
JWT_SECRET=your-long-random-secret

# Seed script (npm run seed) — no sign-up in the app
SEED_ADMIN_EMAIL=admin@yourcompany.com
SEED_ADMIN_PASSWORD=change-this-password

# Or multiple users as JSON:
# SEED_USERS=[{"email":"admin@co.com","password":"secret","name":"Admin"},{"email":"ops@co.com","password":"secret2","name":"Ops"}]
